<?xml version="1.0" encoding="UTF-8"?>
<!--
  CI-specific PHPUnit configuration
  Excludes tests that require production-specific database schema or external services
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.0/phpunit.xsd" 
         colors="true" 
         bootstrap="tests/bootstrap.php" 
         failOnWarning="false" 
         failOnRisky="false" 
         failOnIncomplete="false" 
         failOnSkipped="false" 
         failOnDeprecation="false"
         cacheDirectory=".phpunit.cache">
  <testsuites>
    <testsuite name="Unit">
      <directory suffix="Test.php">tests/Unit</directory>
      <!-- Exclude tests with undefined variables or data-dependent assertions -->
      <exclude>tests/Unit/Controllers/Netcard/EtokenControllerTest.php</exclude>
      <exclude>tests/Unit/Controllers/Dashboard/EnetcardControllerTest.php</exclude>
      <exclude>tests/Unit/Controllers/Dataset/PbiControllerTest.php</exclude>
      <exclude>tests/Unit/Controllers/Mobilization/MapDataControllerTest.php</exclude>
      <exclude>tests/Unit/Controllers/Netcard/NetcardTransControllerTest.php</exclude>
      <exclude>tests/Unit/Controllers/Smc/DashboardControllerTest.php</exclude>
      <exclude>tests/Unit/Controllers/Training/TrainingControllerTest.php</exclude>
    </testsuite>
    <testsuite name="Feature">
      <directory suffix="Test.php">tests/Feature</directory>
      <!-- Exclude tests requiring HTTP server -->
      <exclude>tests/Feature/ApiTest.php</exclude>
      <!-- Exclude tests requiring production schema -->
      <exclude>tests/Feature/Banking/BankingWorkflowTest.php</exclude>
      <exclude>tests/Feature/Banking/BankVerificationEdgeCasesTest.php</exclude>
      <exclude>tests/Feature/FormSubmission/FormSubmissionWorkflowTest.php</exclude>
      <exclude>tests/Feature/Inventory/InventoryManagementWorkflowTest.php</exclude>
      <exclude>tests/Feature/Monitoring/MonitoringWorkflowTest.php</exclude>
      <exclude>tests/Feature/Registration/RegistrationWorkflowTest.php</exclude>
      <exclude>tests/Feature/Users/RoleAssignmentTest.php</exclude>
      <exclude>tests/Feature/Users/UserManagementTest.php</exclude>
      <exclude>tests/Feature/DeviceManagement/DeviceManagementEndpointsTest.php</exclude>
      <exclude>tests/Feature/NetcardManagement/NetcardManagementWorkflowTest.php</exclude>
    </testsuite>
    <testsuite name="Integration">
      <directory suffix="Test.php">tests/Integration</directory>
      <!-- Exclude tests requiring production schema columns -->
      <exclude>tests/Integration/DatabaseSchemaTest.php</exclude>
      <exclude>tests/Integration/Registration/RegistrationTest.php</exclude>
      <exclude>tests/Integration/Dashboard/DashboardControllerTest.php</exclude>
      <exclude>tests/Integration/Mobilization/MobilizationControllerTest.php</exclude>
      <exclude>tests/Integration/Netcard/NetcardComprehensiveTest.php</exclude>
      <exclude>tests/Integration/Netcard/NetcardControllerTest.php</exclude>
      <exclude>tests/Integration/Netcard/NetcardTransactionsTest.php</exclude>
      <exclude>tests/Integration/Users/UserManageTransactionsTest.php</exclude>
      <exclude>tests/Integration/Users/UserManagementTest.php</exclude>
    </testsuite>
  </testsuites>
  <php>
    <env name="IPOLONGO_DB_DSN" value="mysql:host=127.0.0.1;dbname=ipolongo;charset=utf8mb4"/>
    <env name="IPOLONGO_DB_USER" value="root"/>
    <env name="IPOLONGO_DB_PASS" value=""/>
    <env name="IPOLONGO_DB_NAME" value="ipolongo"/>
    <env name="IPOLONGO_DB_HOST" value="127.0.0.1"/>
    <env name="DB_DATABASE" value="ipolongo"/>
    <env name="CI" value="true"/>
  </php>
  <source>
    <include>
      <directory>lib</directory>
    </include>
    <exclude>
      <directory>lib/vendor</directory>
      <file>lib/composer-setup.php</file>
    </exclude>
  </source>
</phpunit>
